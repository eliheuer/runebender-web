# Prefix: Languagesystems
languagesystem DFLT dflt;
languagesystem arab dflt;
languagesystem latn dflt;

@GDEF_MARKS = [acutecomb gravecomb circumflexcomb tildecomb macroncomb brevecomb dotaccentcomb dieresiscomb ringcomb hungarumlautcomb caroncomb cedillacomb ogonekcomb commaaccentcomb smallHighTah-ar smallHighZain-ar invertedDamma-ar fathatan-ar dammatan-ar kasratan-ar fatha-ar damma-ar kasra-ar shadda-ar sukun-ar madda-ar hamzaabove-ar hamzabelow-ar noonGhunna-ar alefbelow-ar alefabove-ar smallHighThreeDots-ar hamzaaboveDamma-ar hamzaaboveDammatan-ar hamzaaboveFatha-ar hamzaaboveFathatan-ar hamzaaboveSukun-ar hamzabelowKasra-ar hamzabelowKasratan-ar shaddaAlefabove-ar shaddaDamma-ar shaddaDammatan-ar shaddaFatha-ar shaddaFathatan-ar shaddaKasra-ar shaddaKasratan-ar];
@FIGURES_PROPORTIONAL = [zero one two three four five six seven eight nine];
@FIGURES_TABULAR = [zero.tf one.tf two.tf three.tf four.tf five.tf six.tf seven.tf eight.tf nine.tf];
@SOFT_DOTTED_BASES = [i j];
@SOFT_DOTTED_DOTLESS = [idotless jdotless];
@SOFT_DOTTED_ABOVE_MARKS = [acutecomb gravecomb circumflexcomb tildecomb macroncomb brevecomb dotaccentcomb dieresiscomb ringcomb hungarumlautcomb caroncomb];

table GDEF {
	GlyphClassDef , , @GDEF_MARKS, ;
} GDEF;

feature aalt {
# automatic
feature tnum;
feature init;
feature medi;
feature fina;
} aalt;

feature tnum {
sub @FIGURES_PROPORTIONAL by @FIGURES_TABULAR;
} tnum;

@ARAB_MARK_BASES = [dottedCircle alef-ar beh-ar teh-ar jeem-ar seen-ar sad-ar tah-ar meem-ar noon-ar heh-ar waw-ar yeh-ar];
@LATIN_TOP_BASES = [J jdotless dottedCircle];

markClass acutecomb <anchor 150 638> @MC_latin_top;

markClass fathatan-ar <anchor 0 0> @MC_top_low;
markClass dammatan-ar <anchor 0 0> @MC_top_low;
markClass fatha-ar <anchor 0 0> @MC_top_low;
markClass damma-ar <anchor 0 0> @MC_top_low;
markClass shadda-ar <anchor 0 0> @MC_top_low;
markClass sukun-ar <anchor 0 0> @MC_top_low;
markClass madda-ar <anchor 0 0> @MC_top_low;
markClass alefabove-ar <anchor 0 0> @MC_top_low;
markClass smallHighTah-ar <anchor 0 576> @MC_top_self;
markClass smallHighZain-ar <anchor 0 576> @MC_top_self;
markClass invertedDamma-ar <anchor 0 576> @MC_top_self;
markClass hamzaabove-ar <anchor 0 576> @MC_top_self;
markClass noonGhunna-ar <anchor 0 576> @MC_top_self;
markClass smallHighThreeDots-ar <anchor 0 576> @MC_top_self;
markClass kasratan-ar <anchor 0 0> @MC_bottom_low;
markClass kasra-ar <anchor 0 0> @MC_bottom_low;
markClass alefbelow-ar <anchor 0 0> @MC_bottom_low;
markClass hamzabelow-ar <anchor 0 0> @MC_bottom_self;

feature mark {
lookup mark_latin_0 {
	pos base @LATIN_TOP_BASES
		<anchor 276 792> mark @MC_latin_top;
} mark_latin_0;

lookup mark_arab_0 {
	pos base @ARAB_MARK_BASES
		<anchor 300 576> mark @MC_top_low
		<anchor 300 576> mark @MC_top_self
		<anchor 300 -144> mark @MC_bottom_low
		<anchor 300 0> mark @MC_bottom_self;
} mark_arab_0;
script DFLT;
language dflt;
lookup mark_latin_0;
lookup mark_arab_0;
script arab;
language dflt;
lookup mark_arab_0;
} mark;

feature mkmk {
lookup mkmk_arab_0 {
	pos mark @MC_top_low <anchor 0 144> mark @MC_top_low;
	pos mark @MC_top_low <anchor 0 720> mark @MC_top_self;
	pos mark @MC_top_self <anchor 0 720> mark @MC_top_low;
	pos mark @MC_top_self <anchor 0 720> mark @MC_top_self;
	pos mark @MC_bottom_low <anchor 0 -144> mark @MC_bottom_low;
	pos mark @MC_bottom_low <anchor 0 -144> mark @MC_bottom_self;
	pos mark @MC_bottom_self <anchor 0 -144> mark @MC_bottom_low;
	pos mark @MC_bottom_self <anchor 0 -144> mark @MC_bottom_self;
} mkmk_arab_0;
script DFLT;
language dflt;
lookup mkmk_arab_0;
script arab;
language dflt;
lookup mkmk_arab_0;
} mkmk;

feature ccmp {
# automatic
	lookup ccmp_soft_dotted_ligature_0 {
		lookupflag 0;
		sub iogonek dotaccentcomb by dotlessiogonek;
	} ccmp_soft_dotted_ligature_0;

	lookup ccmp_soft_dotted_context_1 {
		lookupflag 0;
		sub iogonek' @SOFT_DOTTED_ABOVE_MARKS by dotlessiogonek;
		sub @SOFT_DOTTED_BASES' @SOFT_DOTTED_ABOVE_MARKS by @SOFT_DOTTED_DOTLESS;
	} ccmp_soft_dotted_context_1;

	lookup ccmp_arab_2 {
	lookupflag 0;
	sub hamzaabove-ar damma-ar by hamzaaboveDamma-ar;
	sub damma-ar hamzaabove-ar by hamzaaboveDamma-ar;
	sub hamzaabove-ar dammatan-ar by hamzaaboveDammatan-ar;
	sub dammatan-ar hamzaabove-ar by hamzaaboveDammatan-ar;
	sub hamzaabove-ar fatha-ar by hamzaaboveFatha-ar;
	sub fatha-ar hamzaabove-ar by hamzaaboveFatha-ar;
	sub hamzaabove-ar fathatan-ar by hamzaaboveFathatan-ar;
	sub fathatan-ar hamzaabove-ar by hamzaaboveFathatan-ar;
	sub hamzaabove-ar sukun-ar by hamzaaboveSukun-ar;
	sub sukun-ar hamzaabove-ar by hamzaaboveSukun-ar;
	sub hamzabelow-ar kasra-ar by hamzabelowKasra-ar;
	sub kasra-ar hamzabelow-ar by hamzabelowKasra-ar;
	sub hamzabelow-ar kasratan-ar by hamzabelowKasratan-ar;
	sub kasratan-ar hamzabelow-ar by hamzabelowKasratan-ar;
	sub shadda-ar alefabove-ar by shaddaAlefabove-ar;
	sub alefabove-ar shadda-ar by shaddaAlefabove-ar;
	sub shadda-ar damma-ar by shaddaDamma-ar;
	sub damma-ar shadda-ar by shaddaDamma-ar;
	sub shadda-ar dammatan-ar by shaddaDammatan-ar;
	sub dammatan-ar shadda-ar by shaddaDammatan-ar;
	sub shadda-ar fatha-ar by shaddaFatha-ar;
	sub fatha-ar shadda-ar by shaddaFatha-ar;
	sub shadda-ar fathatan-ar by shaddaFathatan-ar;
	sub fathatan-ar shadda-ar by shaddaFathatan-ar;
	sub shadda-ar kasra-ar by shaddaKasra-ar;
	sub kasra-ar shadda-ar by shaddaKasra-ar;
	sub shadda-ar kasratan-ar by shaddaKasratan-ar;
	sub kasratan-ar shadda-ar by shaddaKasratan-ar;
	} ccmp_arab_2;

script DFLT;
language dflt;
lookup ccmp_soft_dotted_ligature_0;
lookup ccmp_soft_dotted_context_1;
script latn;
language dflt;
lookup ccmp_soft_dotted_ligature_0;
lookup ccmp_soft_dotted_context_1;
script arab;
lookup ccmp_arab_2;
} ccmp;

