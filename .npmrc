# Supply-chain hardening: refuse package versions newer than this cooldown.
# Mitigates compromised-maintainer attacks by giving the community time to
# detect and yank malicious releases before they reach this project.
# Value is in minutes. 10080 = 7 days.
minimum-release-age=10080

# Comma-separated packages that bypass the cooldown. Add internal/first-party
# packages here if they need to publish + consume immediately.
minimum-release-age-exclude=

# Don't auto-reinstall on every `pnpm <script>` run. This is purely
# for the dev-server loop; it doesn't touch the cooldown above. We
# explicitly run `pnpm install` ourselves when deps actually change,
# so the implicit reinstall just keeps wiping the esbuild post-install
# binary that `pnpm rebuild esbuild` had put in place.
verify-deps-before-run=false
